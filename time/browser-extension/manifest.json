{
  "manifest_version": 3,
  "name": "WorkTrail Tracker",
  "version": "0.2.0",
  "description": "Tracks active browser tab sessions for your personal WorkTrail dashboard.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WorkTrail Tracker",
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "https://*.github.io/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
